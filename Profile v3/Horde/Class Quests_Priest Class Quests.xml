		<If Condition="(Me.Class == WoWClass.Priest) &amp;&amp; (Me.Race == WoWRace.Troll)">
			<PickUp QuestName="Hex of Weakness" QuestId="5652" GiverName="Tai'jin" GiverId="3706" />
			<!-- Quest 5652 (Hex of Weakness) — TurnIn NPC not found -->
		</If>

		<If Condition="(Me.Class == WoWClass.Priest) &amp;&amp; (Me.Race == WoWRace.Undead)">
			<PickUp QuestName="Touch of Weakness" QuestId="5658" GiverName="Aelthalyste" GiverId="4606" />
			<!-- Quest 5658 (Touch of Weakness) — TurnIn NPC not found -->
		</If>

		<If Condition="(Me.Class == WoWClass.Priest) &amp;&amp; (Me.Race == WoWRace.Troll)">
			<PickUp QuestName="Shadowguard" QuestId="5643" GiverName="Miles Welsh" GiverId="3044" />
			<!-- Quest 5643 (Shadowguard) — TurnIn NPC not found -->
		</If>

		<If Condition="(Me.Class == WoWClass.Priest) &amp;&amp; (Me.Race == WoWRace.Undead)">
			<PickUp QuestName="Devouring Plague" QuestId="5644" GiverName="Zayus" GiverId="5994" />
			<!-- Quest 5644 (Devouring Plague) — TurnIn NPC not found -->
		</If>

	</QuestOrder>
</HBProfile>